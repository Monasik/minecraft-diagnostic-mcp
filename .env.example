# Core mode selection
MCP_ANALYSIS_MODE=backup
MCP_RUNTIME_BACKEND=docker

# Common filesystem roots
MCP_SERVER_ROOT=.
MCP_PLUGINS_DIR=plugins
MCP_LOGS_DIR=logs

# Docker runtime backend
MCP_CONTAINER_NAME=mc

# Local runtime backend
MCP_LOCAL_SERVER_JAR=purpur.jar
MCP_LOCAL_RCON_HOST=127.0.0.1
MCP_LOCAL_RCON_PORT=25575
MCP_LOCAL_RCON_PASSWORD=change-me

# Optional tuning
MCP_DEFAULT_LOG_LINES=10
MCP_SUBPROCESS_TIMEOUT_SECONDS=30
