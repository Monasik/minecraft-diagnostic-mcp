# MCP transport
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000
MCP_HTTP_PATH=/mcp

# Core mode selection
MCP_ANALYSIS_MODE=backup
MCP_RUNTIME_BACKEND=docker

# Common filesystem roots
MCP_SERVER_ROOT=.
MCP_PLUGINS_DIR=plugins
MCP_LOGS_DIR=logs

# Docker runtime backend
MCP_CONTAINER_NAME=mc

# Local runtime backend
MCP_LOCAL_SERVER_JAR=purpur.jar
MCP_LOCAL_RCON_HOST=127.0.0.1
MCP_LOCAL_RCON_PORT=25575
MCP_LOCAL_RCON_PASSWORD=change-me

# Optional tuning
MCP_DEFAULT_LOG_LINES=10
MCP_SUBPROCESS_TIMEOUT_SECONDS=30
MCP_MAX_LOG_FILES=20
MCP_MAX_LOG_LINES_TOTAL=50000

# Optional Discord alerts
MCP_DISCORD_ALERTS_ENABLED=false
MCP_DISCORD_WEBHOOK_URL=
MCP_DISCORD_ALERT_USERNAME=Minecraft Diagnostic MCP
MCP_DISCORD_ALERT_POLL_SECONDS=30
MCP_DISCORD_ALERT_SCAN_LINES=400
MCP_DISCORD_ALERT_MIN_PRIORITY=50
MCP_DISCORD_ALERT_STATE_FILE=
MCP_DISCORD_ALERT_COOLDOWN_SECONDS=1800
MCP_DISCORD_ALERT_MAX_BATCH_ITEMS=3
